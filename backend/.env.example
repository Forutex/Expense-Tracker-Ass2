# Database configuration
# Format: mysql+pymysql://USERNAME:PASSWORD@HOST/DATABASE_NAME
DATABASE_URL=mysql+pymysql://root:YOUR_MYSQL_PASSWORD@localhost/expense_tracker

# JWT configuration
# Generate a strong secret for production. For local dev, any random string works.
SECRET_KEY=replace-with-a-long-random-string-for-this-project
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60